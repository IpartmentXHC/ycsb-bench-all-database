# Single-host cgroup v2 cpuset example for kunpen183.
# Doris and YCSB run on the same host. Doris uses node0-2; YCSB uses node3.

MODE=singlehost
SERVER_HOST=kunpen183
CLIENT_HOST=kunpen183
EXPERIMENT_NAME=ycsb-singlehost-cgroup2
REMOTE_ROOT=/home/xhc/ExperScript/ycsb-bench-all-database
LOCAL_RESULTS_ROOT=/data/sched-ext-study/ycsb-bench-all-database/experiments

YCSB_HOME=/home/xhc/ycsb-jdbc-binding-0.17.0
PYTHON2_BIN=python2
PYTHON2_LD_LIBRARY_PATH=/usr/local/python2.7/lib
JDBC_URL='jdbc:mysql://127.0.0.1:9030/ycsb?useSSL=false&autoReconnect=true&characterEncoding=utf8&serverTimezone=UTC'
JDBC_USER=root
JDBC_PASSWORD=
JDBC_DRIVER=com.mysql.cj.jdbc.Driver
JDBC_JAR=/home/xhc/ycsb-jdbc-binding-0.17.0/lib/mysql-connector-java-8.0.28.jar
TABLE=usertable

GENERATE_WORKLOAD=1
RECORDCOUNT=1000000
OPERATIONCOUNT_PER_CLIENT=50000
REQUEST_DISTRIBUTION=zipfian
READ_PROPORTION=1
UPDATE_PROPORTION=0
SCAN_PROPORTION=0
INSERT_PROPORTION=0
MATRIX='t80:5:16 t128:8:16 t256:8:32'
ROUNDS=1
STATUS_INTERVAL=10
RUN_SECONDS=1800

ENABLE_CGROUP=1
CGROUP_ROOT=/run/cgroup2/doris-bench
SERVER_CGROUP=/run/cgroup2/doris-bench/doris
CLIENT_CGROUP=/run/cgroup2/doris-bench/ycsb
SERVER_CPUSET_EXPECT=0-95
SERVER_MEMS_EXPECT=0-2
CLIENT_CPUSET_EXPECT=96-127
CLIENT_MEMS_EXPECT=3
CGROUP_WRITE_WITH_SUDO=1
SUDO_ASKPASS=/home/xhc/ExperScript/doris-bench/askpass.sh

ENABLE_THREAD_CLUSTER=0
SERVER_PID_COMMAND='pgrep -x doris_be'
SERVER_SETUP_CMD='SUDO_ASKPASS=/home/xhc/ExperScript/doris-bench/askpass.sh SCHEDULERS=baseline_cfs WORKLOAD_GROUP_MEMORY_LIMIT=95% DORIS_NUMA_MODE=none /home/xhc/ExperScript/doris-bench/doris-server-bench.sh setup baseline_cfs'
SERVER_READY_CMD="mysql -h127.0.0.1 -P9030 -uroot -e 'select 1'"
SERVER_CLEANUP_CMD='SUDO_ASKPASS=/home/xhc/ExperScript/doris-bench/askpass.sh SCHEDULERS=baseline_cfs /home/xhc/ExperScript/doris-bench/doris-server-bench.sh cleanup'
SERVER_WARNING_LOG_GLOB='/home/xhc/doris/apache-doris-2.1.2-bin-arm64/be/log/be*.log'
