# ClickHouse/YCSB dual-host baseline template.
# Fill host, JDBC, startup, and cleanup details before running.

DB_TYPE=clickhouse
MODE=dualhost
SERVER_HOST=clickhouse-server-host
CLIENT_HOST=ycsb-client-host
EXPERIMENT_NAME=clickhouse-dualhost-baseline
REMOTE_ROOT=/home/xhc/ExperScript/ycsb-bench-all-database
LOCAL_RESULTS_ROOT=/data/sched-ext-study/ycsb-bench-all-database/experiments

CLICKHOUSE_HOME=/path/to/clickhouse

YCSB_HOME=/home/xhc/ycsb-jdbc-binding-0.17.0
PYTHON2_BIN=python2
JDBC_URL='jdbc:clickhouse://server-ip:8123/ycsb'
JDBC_USER=default
JDBC_PASSWORD=
JDBC_DRIVER=com.clickhouse.jdbc.ClickHouseDriver
JDBC_JAR=/path/to/clickhouse-jdbc.jar
TABLE=usertable

GENERATE_WORKLOAD=1
RECORDCOUNT=1000000
OPERATIONCOUNT_PER_CLIENT=50000
REQUEST_DISTRIBUTION=zipfian
READ_PROPORTION=1
UPDATE_PROPORTION=0
SCAN_PROPORTION=0
INSERT_PROPORTION=0
MATRIX='t80:5:16'
ROUNDS=1
STATUS_INTERVAL=10
RUN_SECONDS=1800

ENABLE_CGROUP=0
ENABLE_THREAD_CLUSTER=0

# Required for ClickHouse in this version.
SERVER_SETUP_CMD=
SERVER_READY_CMD=
SERVER_CLEANUP_CMD=
SERVER_PID_COMMAND='pgrep -x clickhouse-server'
