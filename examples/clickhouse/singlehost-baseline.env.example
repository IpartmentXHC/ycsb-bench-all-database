# ClickHouse/YCSB single-host baseline template.
# Fill the TODO values before running.

DB_TYPE=clickhouse
MODE=singlehost
SERVER_HOST=localhost
CLIENT_HOST=localhost
EXPERIMENT_NAME=clickhouse-singlehost-baseline
REMOTE_ROOT=/tmp/ycsb-bench-all-database
LOCAL_RESULTS_ROOT=/data/sched-ext-study/ycsb-bench-all-database/experiments

CLICKHOUSE_HOME=/path/to/clickhouse

YCSB_HOME=/home/xhc/ycsb-jdbc-binding-0.17.0
PYTHON2_BIN=python2
JDBC_URL='jdbc:clickhouse://127.0.0.1:8123/ycsb'
JDBC_USER=default
JDBC_PASSWORD=
JDBC_DRIVER=com.clickhouse.jdbc.ClickHouseDriver
JDBC_JAR=/path/to/clickhouse-jdbc.jar
TABLE=usertable

GENERATE_WORKLOAD=1
RECORDCOUNT=1000000
OPERATIONCOUNT_PER_CLIENT=1000
REQUEST_DISTRIBUTION=zipfian
READ_PROPORTION=1
UPDATE_PROPORTION=0
SCAN_PROPORTION=0
INSERT_PROPORTION=0
MATRIX='t1:1:1'
ROUNDS=1
STATUS_INTERVAL=10
RUN_SECONDS=300

ENABLE_CGROUP=0
ENABLE_THREAD_CLUSTER=0

# Required for ClickHouse in this version.
SERVER_SETUP_CMD=
SERVER_READY_CMD=
SERVER_CLEANUP_CMD=
SERVER_PID_COMMAND='pgrep -x clickhouse-server'
