# Dual-host Doris/YCSB with user-space thread clustering.
# Query-path Doris BE threads are pinned to node1. Selected background threads are pinned to node0.

MODE=dualhost
SERVER_HOST=kunpen183
CLIENT_HOST=ubuntu197
EXPERIMENT_NAME=ycsb-dualhost-thread-cluster
REMOTE_ROOT=/home/xhc/ExperScript/ycsb-bench-all-database
LOCAL_RESULTS_ROOT=/data/sched-ext-study/ycsb-bench-all-database/experiments

YCSB_HOME=/home/xhc/ycsb-jdbc-binding-0.17.0
PYTHON2_BIN=python2
JDBC_URL='jdbc:mysql://192.168.70.183:9030/ycsb?useSSL=false&autoReconnect=true&characterEncoding=utf8&serverTimezone=UTC'
JDBC_USER=root
JDBC_PASSWORD=
JDBC_DRIVER=com.mysql.cj.jdbc.Driver
JDBC_JAR=/home/xhc/ycsb-jdbc-binding-0.17.0/lib/mysql-connector-java-8.0.28.jar
TABLE=usertable

GENERATE_WORKLOAD=1
RECORDCOUNT=1000000
OPERATIONCOUNT_PER_CLIENT=50000
REQUEST_DISTRIBUTION=zipfian
READ_PROPORTION=1
UPDATE_PROPORTION=0
SCAN_PROPORTION=0
INSERT_PROPORTION=0
MATRIX='t80:5:16'
ROUNDS=3
STATUS_INTERVAL=10
RUN_SECONDS=1800

ENABLE_CGROUP=0
ENABLE_THREAD_CLUSTER=1
THREAD_CLUSTER_RULES='query:brpc_light|Pipe_normal|Scan_normal:32-63 background:brpc_heavy|Flush|flush|Report|report|TaskWP|Task|tablet|Tablet:0-31'

SERVER_PID_COMMAND='pgrep -x doris_be'
SERVER_SETUP_CMD='SUDO_ASKPASS=/home/xhc/ExperScript/doris-bench/askpass.sh SCHEDULERS=baseline_cfs WORKLOAD_GROUP_MEMORY_LIMIT=95% DORIS_NUMA_MODE=none /home/xhc/ExperScript/doris-bench/doris-server-bench.sh setup baseline_cfs'
SERVER_READY_CMD="mysql -h127.0.0.1 -P9030 -uroot -e 'select 1'"
SERVER_CLEANUP_CMD='SUDO_ASKPASS=/home/xhc/ExperScript/doris-bench/askpass.sh SCHEDULERS=baseline_cfs /home/xhc/ExperScript/doris-bench/doris-server-bench.sh cleanup'
SERVER_WARNING_LOG_GLOB='/home/xhc/doris/apache-doris-2.1.2-bin-arm64/be/log/be*.log'
