# Doris/YCSB dual-host thread-cluster suite template.
# Copy this file, edit host/path/JDBC values, then source it before running:
#   set -a; source examples/doris/dualhost-thread-cluster-suite.env; set +a
#   tools/run-doris-thread-cluster-suite.sh

CONFIG=examples/doris/dualhost-baseline.env
SUITE_NAME=doris-dualhost-thread-cluster-node3-node2-x3

# Remote hosts. SSH aliases or IP addresses are both accepted.
SERVER_HOST=<doris-server-host>
CLIENT_HOST=<ycsb-client-host>

# Paths on remote hosts.
REMOTE_ROOT=/home/xhc/ExperScript/ycsb-bench-all-database
DORIS_HOME=/path/to/apache-doris-bin
YCSB_HOME=/path/to/ycsb-jdbc-binding-0.17.0
PYTHON2_BIN=python2
JDBC_JAR=/path/to/mysql-connector-java-8.0.28.jar

# Doris JDBC endpoint as seen by the YCSB client host.
JDBC_URL='jdbc:mysql://<doris-server-ip>:9030/ycsb?useSSL=false&autoReconnect=true&characterEncoding=utf8&serverTimezone=UTC'
JDBC_USER=root
JDBC_PASSWORD=
TABLE=usertable

# 4 NUMA nodes, 32 CPUs per node, matching kunpen183-style topology:
# node1=32-63, node2=64-95, node3=96-127.
NUMA_CONTROL_NODE=1
NUMA_CONTROL_CPUS=32-63
OTHER_NODE_CPUS=64-95
HOT_NODE_CPUS=96-127

# Doris hot thread groups to cluster on HOT_NODE_CPUS.
HOT_THREAD_REGEX='brpc_heavy|brpc_light|Pipe_normal'
SERVER_PID_COMMAND='pgrep -x doris_be'

# Suite matrix. Format per item:
#   logical_load:matrix_label:client_processes:threads_per_client
SUITE_LOADS='t16:t16:1:16 t80:t80:5:16'
SUITE_PROFILES='baseline numa_node1 cluster_hot_node3_other_node2'
SUITE_ROUNDS=3
OPS_PER_CLIENT=50000
RUN_SECONDS=1800

ENABLE_CGROUP=0
ENABLE_THREAD_CLUSTER=0
DORIS_SWAP_CHECK=1
DORIS_SWAPOFF_WITH_SUDO=0
